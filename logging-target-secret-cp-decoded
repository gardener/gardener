apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  labels:
    app: gardener-opentelemetry-collector
  name: gardener.cloud:logging:opentelemetry-collector
rules:
- apiGroups:
  - ""
  - apps
  resources:
  - nodes
  - nodes/proxy
  - services
  - endpoints
  - pods
  - replicasets
  verbs:
  - get
  - list
  - watch
- nonResourceURLs:
  - /opentelemetry.proto.collector.logs.v1.LogsService/Export
  verbs:
  - create
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  labels:
    app: gardener-opentelemetry-collector
  name: gardener.cloud:logging:opentelemetry-collector
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: gardener.cloud:logging:opentelemetry-collector
subjects:
- kind: ServiceAccount
  name: gardener-opentelemetry-collector
  namespace: kube-system
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  labels:
    app: rbac-proxy
  name: gardener.cloud:logging:rbac-proxy
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: system:auth-delegator
subjects:
- kind: ServiceAccount
  name: rbac-proxy
  namespace: kube-system
