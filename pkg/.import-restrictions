rules:
- selectorRegexp: github[.]com/gardener/gardener
  allowedPrefixes:
  - ''
  forbiddenPrefixes:
  - github.com/gardener/gardener/cmd # envtest overrides this
  - github.com/gardener/gardener/extensions # provider-local, OSC controller, apiserver/registry/core/namespacedcloudprofile, extension controller, ctrlinst controller, OSC node init override this
  - github.com/gardener/gardener/plugin # apiserver, envtest and NSCPFL override this
  - github.com/gardener/gardener/test
