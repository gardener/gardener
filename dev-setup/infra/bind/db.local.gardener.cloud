;
; BIND data file for local.gardener.cloud
;
; DO NOT EDIT THIS FILE while bind9 is running after sending DNS updates (making the zone dynamic).
$TTL    60
@       IN      SOA     ns.local.gardener.cloud. admin.local.gardener.cloud. (
                     2026021101         ; Serial
                             60         ; Refresh
                             60         ; Retry
                        2419200         ; Expire
                              1 )       ; Negative Cache TTL

; Name Servers
@       IN      NS      ns.local.gardener.cloud.
ns      IN      A       172.18.255.53

; Hard-coded registry address reachable from the host and containers, required for pushing from the host and pulling
; from containers.
registry        IN      A       172.18.255.100

; Delegate the registry-cache zone to Docker's built-in DNS server which resolves
; the host aliases configured in the docker compose file.
; We wouldn't need this if we had a separate zones for registry records outside of local.gardener.cloud.
registry-cache  IN      NS      docker-dns.local.gardener.cloud.
docker-dns      IN      A       127.0.0.11
